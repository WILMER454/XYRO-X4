    local targetText = targetPlayerNames == "" and "All players" or targetPlayerNames
    local headText = headSitPlayerNames == "" and "None" or headSitPlayerNames
    local avoidText = avoidPlayerNames == "" and "None" or avoidPlayerNames
    
