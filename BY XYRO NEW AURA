-- ==================== HELPER FUNCTIONS ====================
local function updateTargetList()
    targetList = {}
    if targetPlayerNames == "" then return end
    
    for name in targetPlayerNames:gmatch("[^,]+") do
        local trimmedName = name:gsub("^%s*(.-)%s*$", "%1")
        if trimmedName ~= "" then
            targetList[trimmedName:lower()] = true
        end
    end
end

